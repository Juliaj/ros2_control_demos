<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!--
    Open Duck Mini ros2_control configuration
    Supports both MuJoCo and mock hardware
    Total: 14 DoF (10 leg + 4 head)

    Joint order matches example_config.json joints_offsets (lines 13-28):
    0-4:   Left leg (hip_yaw, hip_roll, hip_pitch, knee, ankle)
    5-8:   Head (neck_pitch, head_pitch, head_yaw, head_roll)
    9-13:  Right leg (hip_yaw, hip_roll, hip_pitch, knee, ankle)

    IMU sensor: imu (10 state interfaces: orientation + angular_velocity + linear_acceleration)
  -->

  <xacro:macro name="open_duck_mini_mujoco_ros2_control" params="name prefix">
    <xacro:open_duck_mini_ros2_control name="${name}" prefix="${prefix}" use_mock_hardware="false"/>
  </xacro:macro>

  <xacro:macro name="open_duck_mini_ros2_control" params="name prefix use_mock_hardware:=^|false">
    <ros2_control name="${name}" type="system">
      <xacro:unless value="${use_mock_hardware}">
        <hardware>
          <plugin>mujoco_ros2_control/MujocoSystemInterface</plugin>
          <param name="mujoco_model">$(find ros2_control_demo_example_18)/description/mujoco/scene.xml</param>
          <param name="meshdir">$(find ros2_control_demo_example_18)/description/assets</param>
          <param name="pids_config_file">$(find ros2_control_demo_example_18)/config/open_duck_mini_pids.yaml</param>
          <!-- Initialize robot from "home" keyframe to match reference implementation -->
          <!-- Source: scene_flat_terrain.xml keyframe "home" -->
          <param name="override_start_position_file">$(find ros2_control_demo_example_18)/description/mujoco/start_positions.xml</param>
        </hardware>
      </xacro:unless>
      <xacro:if value="${use_mock_hardware}">
        <hardware>
          <plugin>mock_components/GenericSystem</plugin>
          <param name="calculate_dynamics">true</param>
        </hardware>
      </xacro:if>

      <!-- Left leg joints -->
      <!-- Order matches example_config.json joints_offsets (lines 14-18) -->
      <joint name="${prefix}left_hip_yaw">
        <command_interface name="position">
          <param name="min">-0.52359877559829881566</param>
          <param name="max">0.52359877559829881566</param>
        </command_interface>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
        <state_interface name="effort"/>
      </joint>
      <joint name="${prefix}left_hip_roll">
        <command_interface name="position">
          <param name="min">-0.43633231299858238339</param>
          <param name="max">0.43633231299858238339</param>
        </command_interface>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
        <state_interface name="effort"/>
      </joint>
      <joint name="${prefix}left_hip_pitch">
        <command_interface name="position">
          <param name="min">-1.2217304763960306069</param>
          <param name="max">0.52359877559829881566</param>
        </command_interface>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
        <state_interface name="effort"/>
      </joint>
      <joint name="${prefix}left_knee">
        <command_interface name="position">
          <param name="min">-1.570796326794896558</param>
          <param name="max">1.570796326794896558</param>
        </command_interface>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
        <state_interface name="effort"/>
      </joint>
      <joint name="${prefix}left_ankle">
        <command_interface name="position">
          <param name="min">-1.570796326794896558</param>
          <param name="max">1.570796326794896558</param>
        </command_interface>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
        <state_interface name="effort"/>
      </joint>

      <!-- Head joints (4 DoF) -->
      <!-- Order matches example_config.json joints_offsets (lines 19-22) -->
      <!-- These joints receive additional head commands via velocity_commands[3:7] -->
      <!-- Source: v2_rl_walk_mujoco.py lines 310-311, biped_robot_controllers.yaml head_joint_indices -->
      <joint name="${prefix}neck_pitch">
        <command_interface name="position">
          <param name="min">-0.3490658503988437</param>  <!-- ~-20 degrees -->
          <param name="max">1.1344640137963364</param>   <!-- ~65 degrees -->
        </command_interface>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
        <state_interface name="effort"/>
      </joint>
      <joint name="${prefix}head_pitch">
        <command_interface name="position">
          <param name="min">-0.785398163397448279</param>  <!-- -45 degrees -->
          <param name="max">0.785398163397448279</param>   <!-- +45 degrees -->
        </command_interface>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
        <state_interface name="effort"/>
      </joint>
      <joint name="${prefix}head_yaw">
        <command_interface name="position">
          <param name="min">-2.792526803190927</param>  <!-- ~-160 degrees -->
          <param name="max">2.792526803190927</param>   <!-- ~+160 degrees -->
        </command_interface>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
        <state_interface name="effort"/>
      </joint>
      <joint name="${prefix}head_roll">
        <command_interface name="position">
          <param name="min">-0.523598775598218</param>  <!-- ~-30 degrees -->
          <param name="max">0.5235987755983796</param>   <!-- ~+30 degrees -->
        </command_interface>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
        <state_interface name="effort"/>
      </joint>

      <!-- Right leg joints -->
      <!-- Order matches example_config.json joints_offsets (lines 23-27) -->
      <joint name="${prefix}right_hip_yaw">
        <command_interface name="position">
          <param name="min">-0.52359877559829881566</param>
          <param name="max">0.52359877559829881566</param>
        </command_interface>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
        <state_interface name="effort"/>
      </joint>
      <joint name="${prefix}right_hip_roll">
        <command_interface name="position">
          <param name="min">-0.43633231299858238339</param>
          <param name="max">0.43633231299858238339</param>
        </command_interface>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
        <state_interface name="effort"/>
      </joint>
      <joint name="${prefix}right_hip_pitch">
        <command_interface name="position">
          <param name="min">-0.52359877559829881566</param>
          <param name="max">1.2217304763960306069</param>
        </command_interface>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
        <state_interface name="effort"/>
      </joint>
      <joint name="${prefix}right_knee">
        <command_interface name="position">
          <param name="min">-1.570796326794896558</param>
          <param name="max">1.570796326794896558</param>
        </command_interface>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
        <state_interface name="effort"/>
      </joint>
      <joint name="${prefix}right_ankle">
        <command_interface name="position">
          <param name="min">-1.570796326794896558</param>
          <param name="max">1.570796326794896558</param>
        </command_interface>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
        <state_interface name="effort"/>
      </joint>

      <!-- IMU sensor - matches Playground sensor names -->
      <!-- MuJoCo sensors: orientation (framequat), gyro, accelerometer -->
      <!-- For mock hardware, sensor interfaces are still available but will return default values -->
      <sensor name="${prefix}imu">
        <xacro:unless value="${use_mock_hardware}">
          <param name="mujoco_type">imu</param>
          <param name="mujoco_orientation_sensor">orientation</param>
          <param name="mujoco_gyro_sensor">gyro</param>
          <param name="mujoco_accel_sensor">accelerometer</param>
        </xacro:unless>
        <state_interface name="orientation.w"/>
        <state_interface name="orientation.x"/>
        <state_interface name="orientation.y"/>
        <state_interface name="orientation.z"/>
        <state_interface name="angular_velocity.x"/>
        <state_interface name="angular_velocity.y"/>
        <state_interface name="angular_velocity.z"/>
        <state_interface name="linear_acceleration.x"/>
        <state_interface name="linear_acceleration.y"/>
        <state_interface name="linear_acceleration.z"/>
      </sensor>
    </ros2_control>

  </xacro:macro>

</robot>
